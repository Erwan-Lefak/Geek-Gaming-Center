// ============================================
// GEEK GAMING CENTER - CRM PRISMA SCHEMA
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTHENTIFICATION & UTILISATEURS
// ============================================

model User {
  id            String    @id @default(cuid()) @map("id")
  email         String    @unique @map("email")
  password      String    @map("password")
  name          String    @map("name")
  role          UserRole  @default(CASHIER) @map("role")
  phone         String?   @map("phone")
  isActive      Boolean   @default(true) @map("is_active")
  lastLogin     DateTime? @map("last_login")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  createdCustomers Customer[] @relation("CreatedBy")
  sessions         GamingSession[]
  invoices         Invoice[]
  maintenanceTickets MaintenanceTicket[]
  auditLogs        AuditLog[]

  @@index([email])
  @@index([role])
  @@map("users")
}

enum UserRole {
  CASHIER        // Caissière
  TECHNICIAN     // Technicien
  MANAGER        // Gérant
  SHAREHOLDER    // Actionnaire
  ADMIN          // Administrateur système

  @@map("userrole")
}

// ============================================
// CLIENTS
// ============================================

model Customer {
  id            String       @id @default(cuid()) @map("id")
  firstName     String       @map("first_name")
  lastName      String       @map("last_name")
  email         String?      @unique @map("email")
  phone         String       @map("phone")
  dateOfBirth   DateTime?    @map("date_of_birth")
  address       String?      @map("address")
  city          String?      @map("city")
  status        CustomerStatus @default(NEW) @map("status")
  notes         String?      @map("notes")
  acceptCGV     Boolean      @default(false) @map("accept_cgv")
  cgvAcceptedAt DateTime?    @map("cgv_accepted_at")
  totalSpent    Decimal      @default(0) @db.Decimal(12, 2) @map("total_spent")
  totalHours    Decimal      @default(0) @db.Decimal(10, 2) @map("total_hours")
  visitCount    Int          @default(0) @map("visit_count")
  lastVisit     DateTime?    @map("last_visit")

  // CRM
  tags          String[]     @map("tags")
  preferences   Json?        @map("preferences")

  createdById   String       @map("created_by_id")
  createdBy     User         @relation("CreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  // Relations
  sessions      GamingSession[]
  reservations  Reservation[]
  invoices      Invoice[]
  cartItems     CartItem[]

  @@index([email])
  @@index([phone])
  @@index([status])
  @@index([lastVisit])
  @@map("customers")
}

enum CustomerStatus {
  NEW       // Nouveau client (moins de 3 visites)
  REGULAR   // Client régulier (3-10 visites)
  VIP       // Client VIP (plus de 10 visites ou fort dépensier)
  INACTIVE  // Inactif depuis plus de 3 mois
  BLOCKED   // Client bloqué

  @@map("customerstatus")
}

// ============================================
// ÉQUIPEMENTS & TARIFICATION
// ============================================

model Equipment {
  id              String          @id @default(cuid()) @map("id")
  name            String          @map("name")
  type            EquipmentType   @map("type")
  code            String          @unique @map("code") // "PS5-01", "PC-GAMING-01"
  status          EquipmentStatus @default(AVAILABLE) @map("status")
  specifications  Json?           @map("specifications")

  // Emplacement
  location        String?         @map("location") // Zone, rangée, numéro

  // Maintenance
  lastMaintenance DateTime?       @map("last_maintenance")
  nextMaintenance DateTime?       @map("next_maintenance")
  healthScore     Int             @default(100) @map("health_score") // 0-100

  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  // Relations
  pricing         Pricing[]
  sessions        GamingSession[]
  reservations    Reservation[]
  maintenanceTickets MaintenanceTicket[]

  @@index([type])
  @@index([status])
  @@index([code])
  @@map("equipment")
}

enum EquipmentType {
  @@map("equipmenttype")
  PS5
  PS4
  XBOX_SERIES_X
  XBOX_ONE
  PC_GAMING
  OCULUS_VR
  VR_PS4
  SIMU_RACING
  ARCADE
  RETRO
}

enum EquipmentStatus {
  @@map("equipmentstatus")
  AVAILABLE
  IN_USE
  RESERVED
  MAINTENANCE
  BROKEN
  RETIRED
}

model Pricing {
  id              String       @id @default(cuid()) @map("id")
  equipmentId     String       @map("equipment_id")
  equipment       Equipment    @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  duration        Int          @map("duration") // Durée en minutes
  isWeekend       Boolean      @default(false) @map("is_weekend")
  price           Decimal      @db.Decimal(10, 2) @map("price")
  currency        String       @default("XAF") @map("currency") // FCFA

  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  sessions        GamingSession[]

  @@unique([equipmentId, duration, isWeekend])
  @@index([equipmentId])
  @@map("pricing")
}

// ============================================
// SESSIONS DE GAMING
// ============================================

model GamingSession {
  id              String            @id @default(cuid()) @map("id")
  sessionNumber   String            @unique @map("session_number")

  customerId      String            @map("customer_id")
  customer        Customer          @relation(fields: [customerId], references: [id])

  equipmentId     String            @map("equipment_id")
  equipment       Equipment         @relation(fields: [equipmentId], references: [id])

  // Tarification
  pricingId       String            @map("pricing_id")
  pricing         Pricing           @relation(fields: [pricingId], references: [id])
  duration        Int               @map("duration") // Durée payée en minutes
  price           Decimal           @db.Decimal(10, 2) @map("price")

  // Statut session
  status          SessionStatus     @default(PENDING) @map("status")

  // Horaires
  paidAt          DateTime          @map("paid_at")
  startedAt       DateTime?         @map("started_at")
  scheduledEndAt  DateTime          @map("scheduled_end_at")
  actualEndAt     DateTime?         @map("actual_end_at")

  // Délai d'installation (5 min)
  gracePeriodEnd  DateTime?         @map("grace_period_end")

  // Extensions de temps
  extensions      SessionExtension[]

  // Notes
  notes           String?           @map("notes")

  // Création et modification
  createdById     String            @map("created_by_id")
  createdBy       User              @relation(fields: [createdById], references: [id])
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  // Facturation
  invoiceId       String?           @unique @map("invoice_id")
  invoice         Invoice?          @relation("GamingSessionToInvoice", fields: [invoiceId], references: [id])

  @@index([customerId])
  @@index([equipmentId])
  @@index([status])
  @@index([scheduledEndAt])
  @@index([sessionNumber])
  @@map("gaming_sessions")
}

model SessionExtension {
  id              String        @id @default(cuid()) @map("id")
  sessionId       String        @map("session_id")
  session         GamingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  additionalMinutes Int         @map("additional_minutes")
  additionalPrice  Decimal      @db.Decimal(10, 2) @map("additional_price")
  extendedAt       DateTime     @default(now()) @map("extended_at")

  @@index([sessionId])
  @@map("session_extensions")
}

enum SessionStatus {
  @@map("sessionstatus")
  PENDING      // Payé, pas encore démarré (délai 5 min)
  ACTIVE       // En cours
  PAUSED       // En pause
  COMPLETED    // Terminé normalement
  EXPIRED      // Temps écoulé
  CANCELLED    // Annulé
}

// ============================================
// FACTURATION
// ============================================

model Invoice {
  id              String        @id @default(cuid()) @map("id")
  invoiceNumber   String        @unique @map("invoice_number")
  invoiceDate     DateTime      @default(now()) @map("invoice_date")
  dueDate         DateTime?     @map("due_date")

  customerId      String        @map("customer_id")
  customer        Customer      @relation(fields: [customerId], references: [id])

  // Montants
  subtotal        Decimal       @db.Decimal(12, 2) @map("subtotal")
  taxRate         Decimal       @default(19.25) @db.Decimal(5, 2) @map("tax_rate") // TVA Cameroun
  taxAmount       Decimal       @db.Decimal(12, 2) @map("tax_amount")
  total           Decimal       @db.Decimal(12, 2) @map("total")
  discount        Decimal       @default(0) @db.Decimal(10, 2) @map("discount")

  // Paiement
  paymentMethod   PaymentMethod @map("payment_method")
  paymentStatus   PaymentStatus @default(PENDING) @map("payment_status")
  paidAt          DateTime?     @map("paid_at")

  // Mobile Money
  mobileMoneyProvider String?    @map("mobile_money_provider") // "ORANGE", "MTN"
  mobileMoneyPhone    String?    @map("mobile_money_phone")
  mobileMoneyRef      String?    @map("mobile_money_ref") // Référence transaction

  // Détails
  type            InvoiceType   @map("type")
  items           InvoiceItem[] @relation("InvoiceItemToInvoice")
  notes           String?       @map("notes")

  createdById     String        @map("created_by_id")
  createdBy       User          @relation(fields: [createdById], references: [id])
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Relations
  session         GamingSession? @relation("GamingSessionToInvoice")

  @@index([invoiceNumber])
  @@index([customerId])
  @@index([invoiceDate])
  @@index([paymentStatus])
  @@map("invoices")
}

model InvoiceItem {
  id              String    @id @default(cuid()) @map("id")
  invoiceId       String    @map("invoice_id")
  invoice         Invoice   @relation("InvoiceItemToInvoice", fields: [invoiceId], references: [id], onDelete: Cascade)
  productId       String?   @map("product_id")
  product         Product?  @relation(fields: [productId], references: [id])
  description     String    @map("description")
  quantity        Int       @map("quantity")
  unitPrice       Decimal   @db.Decimal(10, 2) @map("unit_price")
  totalPrice      Decimal   @db.Decimal(10, 2) @map("total_price")

  @@index([invoiceId])
  @@index([productId])
  @@map("invoice_items")
}

enum InvoiceType {
  @@map("invoicetype")
  GAMING_SESSION
  BOUTIQUE_SALE
  RESERVATION
  CREDIT_NOTE
}

enum PaymentMethod {
  @@map("paymentmethod")
  CASH
  MOBILE_MONEY_ORANGE
  MOBILE_MONEY_MTN
  CARD
  BANK_TRANSFER
}

enum PaymentStatus {
  @@map("paymentstatus")
  PENDING
  PAID
  PARTIALLY_PAID
  CANCELLED
  REFUNDED
}

// ============================================
// BOUTIQUE & STOCKS
// ============================================

model Product {
  id              String        @id @default(cuid()) @map("id")
  name            String        @map("name")
  description     String?       @map("description")
  category        String        @map("category")
  subcategory     String?       @map("subcategory")
  brand           String?       @map("brand")
  sku             String        @unique @map("sku")

  // Prix
  costPrice       Decimal       @db.Decimal(10, 2) @map("cost_price")
  sellingPrice    Decimal       @db.Decimal(10, 2) @map("selling_price")
  currency        String        @default("XAF") @map("currency")

  // Stock
  currentStock    Int           @default(0) @map("current_stock")
  minStock        Int           @default(5) @map("min_stock")
  maxStock        Int           @default(50) @map("max_stock")
  reorderPoint    Int           @default(10) @map("reorder_point")

  // Fournisseur
  supplierId      String?       @map("supplier_id")
  supplier        Supplier?     @relation(fields: [supplierId], references: [id])

  // Images
  images          String[]      @map("images")
  thumbnail       String?       @map("thumbnail")

  // Statuts
  isActive        Boolean       @default(true) @map("is_active")
  isFeatured      Boolean       @default(false) @map("is_featured")

  // Métadonnées
  specifications  Json?         @map("specifications")
  tags            String[]      @map("tags")

  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Relations
  stockMovements  StockMovement[] @relation("ProductToStockMovement")
  cartItems       CartItem[]
  invoiceItems    InvoiceItem[]

  @@index([category])
  @@index([sku])
  @@index([currentStock])
  @@map("products")
}

model StockMovement {
  id              String          @id @default(cuid()) @map("id")
  productId       String          @map("product_id")
  product         Product         @relation("ProductToStockMovement", fields: [productId], references: [id], onDelete: Cascade)
  quantity        Int             @map("quantity") // Positif = entrée, Négatif = sortie
  type            MovementType    @map("type")
  reason          String?         @map("reason")
  reference       String?         @map("reference") // Bon de livraison, facture, etc.

  // Valeur (pour valorisation stock)
  unitCost        Decimal?        @db.Decimal(10, 2) @map("unit_cost")
  totalValue      Decimal?        @db.Decimal(12, 2) @map("total_value")

  createdAt       DateTime        @default(now()) @map("created_at")

  @@index([productId])
  @@index([type])
  @@index([createdAt])
  @@map("stock_movements")
}

enum MovementType {
  @@map("movementtype")
  PURCHASE       // Entrée achat
  SALE           // Sortie vente
  RETURN         // Retour client
  ADJUSTMENT     // Ajustement inventaire
  DAMAGE         // Casse/détérioration
  TRANSFER       // Transfert
  INITIAL        // Stock initial
}

model Supplier {
  id              String        @id @default(cuid()) @map("id")
  name            String        @map("name")
  contactPerson   String?       @map("contact_person")
  email           String?       @map("email")
  phone           String        @map("phone")
  address         String?       @map("address")
  city            String?       @map("city")
  country         String        @default("Cameroun") @map("country")

  // Conditions
  paymentTerms    String?       @map("payment_terms") // "30 jours", "comptant"
  leadTime        Int?          @map("lead_time") // Délai de livraison en jours
  notes           String?       @map("notes")

  isActive        Boolean       @default(true) @map("is_active")

  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Relations
  products        Product[]

  @@index([name])
  @@map("suppliers")
}

// ============================================
// RÉSERVATIONS
// ============================================

model Reservation {
  id              String          @id @default(cuid()) @map("id")
  reservationNumber String        @unique @map("reservation_number")

  customerId      String          @map("customer_id")
  customer        Customer        @relation(fields: [customerId], references: [id])

  equipmentId     String          @map("equipment_id")
  equipment       Equipment       @relation(fields: [equipmentId], references: [id])

  // Période
  startTime       DateTime        @map("start_time")
  endTime         DateTime        @map("end_time")
  duration        Int             @map("duration") // en minutes

  // Tarif & Paiement
  estimatedPrice  Decimal         @db.Decimal(10, 2) @map("estimated_price")
  depositAmount   Decimal         @db.Decimal(10, 2) @map("deposit_amount")
  depositPaid     Boolean         @default(false) @map("deposit_paid")
  depositPaidAt   DateTime?       @map("deposit_paid_at")

  // Statut
  status          ReservationStatus @default(PENDING) @map("status")

  // Confirmation & Rappels
  confirmedAt     DateTime?       @map("confirmed_at")
  reminderSent    Boolean         @default(false) @map("reminder_sent")
  reminderSentAt  DateTime?       @map("reminder_sent_at")

  // No-show & Annulation
  noShow          Boolean         @default(false) @map("no_show")
  cancelledAt     DateTime?       @map("cancelled_at")
  cancellationReason String?      @map("cancellation_reason")

  notes           String?         @map("notes")

  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@index([customerId])
  @@index([equipmentId])
  @@index([startTime])
  @@index([status])
  @@map("reservations")
}

enum ReservationStatus {
  @@map("reservationstatus")
  PENDING
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ============================================
// MAINTENANCE TECHNIQUE
// ============================================

model MaintenanceTicket {
  id              String              @id @default(cuid()) @map("id")
  ticketNumber    String              @unique @map("ticket_number")

  equipmentId     String              @map("equipment_id")
  equipment       Equipment           @relation(fields: [equipmentId], references: [id])

  // Description
  title           String              @map("title")
  description     String              @map("description")
  priority        Priority            @default(MEDIUM) @map("priority")
  status          TicketStatus        @default(OPEN) @map("status")

  // Diagnostic
  diagnosis       String?             @map("diagnosis")
  solution        String?             @map("solution")

  assignedToId    String?             @map("assigned_to_id")
  assignedTo      User?               @relation(fields: [assignedToId], references: [id])
  completedAt     DateTime?           @map("completed_at")
  resolvedAt      DateTime?           @map("resolved_at")

  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  @@index([equipmentId])
  @@index([status])
  @@index([priority])
  @@map("maintenance_tickets")
}

enum Priority {
  @@map("priority")
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  @@map("ticketstatus")
  OPEN
  IN_PROGRESS
  WAITING_PARTS
  RESOLVED
  CLOSED
}

// ============================================
// REPORTING & ANALYTICS
// ============================================

model DailyReport {
  id              String    @id @default(cuid()) @map("id")
  date            DateTime  @unique @map("date")
  dayOfWeek       Int       @map("day_of_week")

  // Chiffre d'affaires
  gamingRevenue   Decimal   @default(0) @db.Decimal(12, 2) @map("gaming_revenue")
  boutiqueRevenue Decimal   @default(0) @db.Decimal(12, 2) @map("boutique_revenue")
  totalRevenue    Decimal   @default(0) @db.Decimal(12, 2) @map("total_revenue")

  // Taxes
  taxCollected    Decimal   @default(0) @db.Decimal(12, 2) @map("tax_collected")

  // Sessions
  sessionCount    Int       @default(0) @map("session_count")
  totalHours      Decimal   @default(0) @db.Decimal(10, 2) @map("total_hours")

  // Clients
  uniqueCustomers Int       @default(0) @map("unique_customers")
  newCustomers    Int       @default(0) @map("new_customers")

  // Paiements
  cashPayments    Decimal   @default(0) @db.Decimal(10, 2) @map("cash_payments")
  mobileMoneyPayments Decimal @default(0) @db.Decimal(10, 2) @map("mobile_money_payments")
  cardPayments    Decimal   @default(0) @db.Decimal(10, 2) @map("card_payments")

  // Top équipements
  topEquipment    Json?     @map("top_equipment")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([date])
  @@map("daily_reports")
}

model MonthlyReport {
  id              String    @id @default(cuid()) @map("id")
  year            Int       @map("year")
  month           Int       @map("month")
  uniqueDate      DateTime  @unique @map("unique_date")

  // CA mensuel
  gamingRevenue   Decimal   @default(0) @db.Decimal(12, 2) @map("gaming_revenue")
  boutiqueRevenue Decimal   @default(0) @db.Decimal(12, 2) @map("boutique_revenue")
  totalRevenue    Decimal   @default(0) @db.Decimal(12, 2) @map("total_revenue")

  // Objectifs
  monthlyTarget   Decimal   @db.Decimal(12, 2) @map("monthly_target")
  targetAchieved  Boolean   @map("target_achieved")
  achievementRate Decimal   @db.Decimal(5, 2) @map("achievement_rate")

  // Sessions
  sessionCount    Int       @default(0) @map("session_count")
  totalHours      Decimal   @default(0) @db.Decimal(10, 2) @map("total_hours")
  avgSessionDuration Decimal @db.Decimal(10, 2) @map("avg_session_duration")

  // Clients
  uniqueCustomers Int       @default(0) @map("unique_customers")
  newCustomers    Int       @default(0) @map("new_customers")
  returningCustomers Int    @default(0) @map("returning_customers")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([year, month])
  @@map("monthly_reports")
}

// ============================================
// PANIER (SESSION TEMPORAIRE)
// ============================================

model CartItem {
  id          String    @id @default(cuid()) @map("id")
  sessionId   String    @unique @map("session_id") // Session ID temporaire

  customerId  String?   @map("customer_id")
  customer    Customer? @relation(fields: [customerId], references: [id])

  productId   String    @map("product_id")
  product     Product   @relation(fields: [productId], references: [id])
  quantity    Int       @map("quantity")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([sessionId])
  @@index([customerId])
  @@map("cart_items")
}

// ============================================
// AUDIT & JOURNALISATION
// ============================================

model AuditLog {
  id          String    @id @default(cuid()) @map("id")
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id])
  action      String    @map("action")
  entity      String    @map("entity") // Type d'entité modifiée
  entityId    String    @map("entity_id")
  changes     Json?     @map("changes") // Diff des changements
  ipAddress   String?   @map("ip_address")
  userAgent   String?   @map("user_agent")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}
