generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid()) @map("id")
  email              String              @unique @map("email")
  password           String              @map("password")
  name               String              @map("name")
  phone              String?             @map("phone")
  isActive           Boolean             @default(true) @map("is_active")
  lastLogin          DateTime?           @map("last_login")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  role               UserRole            @default(CASHIER) @map("role")
  auditLogs          AuditLog[]
  createdCustomers   Customer[]          @relation("CreatedBy")
  sessions           GamingSession[]
  invoices           Invoice[]
  maintenanceTickets MaintenanceTicket[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model Customer {
  id            String          @id @default(cuid()) @map("id")
  firstName     String          @map("first_name")
  lastName      String          @map("last_name")
  email         String?         @unique @map("email")
  phone         String          @map("phone")
  dateOfBirth   DateTime?       @map("date_of_birth")
  address       String?         @map("address")
  city          String?         @map("city")
  notes         String?         @map("notes")
  acceptCGV     Boolean         @default(false) @map("accept_cgv")
  cgvAcceptedAt DateTime?       @map("cgv_accepted_at")
  totalSpent    Decimal         @default(0) @map("total_spent") @db.Decimal(12, 2)
  totalHours    Decimal         @default(0) @map("total_hours") @db.Decimal(10, 2)
  visitCount    Int             @default(0) @map("visit_count")
  lastVisit     DateTime?       @map("last_visit")
  createdById   String          @map("created_by_id")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  preferences   Json?           @map("preferences")
  tags          String[]        @map("tags")
  status        CustomerStatus  @default(NEW) @map("status")
  cartItems     CartItem[]
  createdBy     User            @relation("CreatedBy", fields: [createdById], references: [id])
  eventBookings EventBooking[]
  sessions      GamingSession[]
  invoices      Invoice[]
  reservations  Reservation[]

  @@index([email])
  @@index([phone])
  @@index([status])
  @@index([lastVisit])
  @@map("customers")
}

model Equipment {
  id                 String              @id @default(cuid()) @map("id")
  name               String              @map("name")
  type               EquipmentType       @map("type")
  code               String              @unique @map("code")
  status             EquipmentStatus     @default(AVAILABLE) @map("status")
  specifications     Json?               @map("specifications")
  location           String?             @map("location")
  lastMaintenance    DateTime?           @map("last_maintenance")
  nextMaintenance    DateTime?           @map("next_maintenance")
  healthScore        Int                 @default(100) @map("health_score")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  sessions           GamingSession[]
  maintenanceTickets MaintenanceTicket[]
  pricing            Pricing[]
  reservations       Reservation[]

  @@index([type])
  @@index([status])
  @@index([code])
  @@map("equipment")
}

model Pricing {
  id          String          @id @default(cuid()) @map("id")
  equipmentId String          @map("equipment_id")
  duration    Int             @map("duration")
  isWeekend   Boolean         @default(false) @map("is_weekend")
  price       Decimal         @map("price") @db.Decimal(10, 2)
  currency    String          @default("XAF") @map("currency")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  sessions    GamingSession[]
  equipment   Equipment       @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@unique([equipmentId, duration, isWeekend])
  @@index([equipmentId])
  @@map("pricing")
}

model GamingSession {
  id             String             @id @default(cuid()) @map("id")
  sessionNumber  String             @unique @map("session_number")
  customerId     String             @map("customer_id")
  equipmentId    String             @map("equipment_id")
  pricingId      String             @map("pricing_id")
  duration       Int                @map("duration")
  price          Decimal            @map("price") @db.Decimal(10, 2)
  status         SessionStatus      @default(PENDING) @map("status")
  paidAt         DateTime           @map("paid_at")
  startedAt      DateTime?          @map("started_at")
  scheduledEndAt DateTime           @map("scheduled_end_at")
  actualEndAt    DateTime?          @map("actual_end_at")
  gracePeriodEnd DateTime?          @map("grace_period_end")
  notes          String?            @map("notes")
  createdById    String             @map("created_by_id")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  invoiceId      String?            @unique @map("invoice_id")
  createdBy      User               @relation(fields: [createdById], references: [id])
  customer       Customer           @relation(fields: [customerId], references: [id])
  equipment      Equipment          @relation(fields: [equipmentId], references: [id])
  invoice        Invoice?           @relation("GamingSessionToInvoice", fields: [invoiceId], references: [id])
  pricing        Pricing            @relation(fields: [pricingId], references: [id])
  extensions     SessionExtension[]

  @@index([customerId])
  @@index([equipmentId])
  @@index([status])
  @@index([scheduledEndAt])
  @@index([sessionNumber])
  @@map("gaming_sessions")
}

model SessionExtension {
  id                String        @id @default(cuid()) @map("id")
  sessionId         String        @map("session_id")
  additionalMinutes Int           @map("additional_minutes")
  additionalPrice   Decimal       @map("additional_price") @db.Decimal(10, 2)
  extendedAt        DateTime      @default(now()) @map("extended_at")
  session           GamingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("session_extensions")
}

model Invoice {
  id                  String         @id @default(cuid()) @map("id")
  invoiceNumber       String         @unique @map("invoice_number")
  invoiceDate         DateTime       @default(now()) @map("invoice_date")
  dueDate             DateTime?      @map("due_date")
  customerId          String         @map("customer_id")
  subtotal            Decimal        @map("subtotal") @db.Decimal(12, 2)
  taxRate             Decimal        @default(19.25) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount           Decimal        @map("tax_amount") @db.Decimal(12, 2)
  total               Decimal        @map("total") @db.Decimal(12, 2)
  discount            Decimal        @default(0) @map("discount") @db.Decimal(10, 2)
  paymentMethod       PaymentMethod  @map("payment_method")
  paymentStatus       PaymentStatus  @default(PENDING) @map("payment_status")
  paidAt              DateTime?      @map("paid_at")
  mobileMoneyProvider String?        @map("mobile_money_provider")
  mobileMoneyPhone    String?        @map("mobile_money_phone")
  mobileMoneyRef      String?        @map("mobile_money_ref")
  type                InvoiceType    @map("type")
  notes               String?        @map("notes")
  createdById         String         @map("created_by_id")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")
  session             GamingSession? @relation("GamingSessionToInvoice")
  items               InvoiceItem[]  @relation("InvoiceItemToInvoice")
  createdBy           User           @relation(fields: [createdById], references: [id])
  customer            Customer       @relation(fields: [customerId], references: [id])

  @@index([invoiceNumber])
  @@index([customerId])
  @@index([invoiceDate])
  @@index([paymentStatus])
  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(cuid()) @map("id")
  invoiceId   String   @map("invoice_id")
  productId   String?  @map("product_id")
  description String   @map("description")
  quantity    Int      @map("quantity")
  unitPrice   Decimal  @map("unit_price") @db.Decimal(10, 2)
  totalPrice  Decimal  @map("total_price") @db.Decimal(10, 2)
  invoice     Invoice  @relation("InvoiceItemToInvoice", fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@index([productId])
  @@map("invoice_items")
}

model Product {
  id             String          @id @default(cuid()) @map("id")
  name           String          @map("name")
  description    String?         @map("description")
  category       String          @map("category")
  subcategory    String?         @map("subcategory")
  brand          String?         @map("brand")
  sku            String          @unique @map("sku")
  costPrice      Decimal         @map("cost_price") @db.Decimal(10, 2)
  sellingPrice   Decimal         @map("selling_price") @db.Decimal(10, 2)
  currency       String          @default("XAF") @map("currency")
  currentStock   Int             @default(0) @map("current_stock")
  minStock       Int             @default(5) @map("min_stock")
  maxStock       Int             @default(50) @map("max_stock")
  reorderPoint   Int             @default(10) @map("reorder_point")
  supplierId     String?         @map("supplier_id")
  images         String[]        @map("images")
  thumbnail      String?         @map("thumbnail")
  isActive       Boolean         @default(true) @map("is_active")
  isFeatured     Boolean         @default(false) @map("is_featured")
  specifications Json?           @map("specifications")
  tags           String[]        @map("tags")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  cartItems      CartItem[]
  invoiceItems   InvoiceItem[]
  supplier       Supplier?       @relation(fields: [supplierId], references: [id])
  stockMovements StockMovement[] @relation("ProductToStockMovement")

  @@index([category])
  @@index([sku])
  @@index([currentStock])
  @@map("products")
}

model StockMovement {
  id         String       @id @default(cuid()) @map("id")
  productId  String       @map("product_id")
  quantity   Int          @map("quantity")
  type       MovementType @map("type")
  reason     String?      @map("reason")
  reference  String?      @map("reference")
  unitCost   Decimal?     @map("unit_cost") @db.Decimal(10, 2)
  totalValue Decimal?     @map("total_value") @db.Decimal(12, 2)
  createdAt  DateTime     @default(now()) @map("created_at")
  product    Product      @relation("ProductToStockMovement", fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([type])
  @@index([createdAt])
  @@map("stock_movements")
}

model Supplier {
  id            String    @id @default(cuid()) @map("id")
  name          String    @map("name")
  contactPerson String?   @map("contact_person")
  email         String?   @map("email")
  phone         String    @map("phone")
  address       String?   @map("address")
  city          String?   @map("city")
  country       String    @default("Cameroun") @map("country")
  paymentTerms  String?   @map("payment_terms")
  leadTime      Int?      @map("lead_time")
  notes         String?   @map("notes")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  products      Product[]

  @@index([name])
  @@map("suppliers")
}

model Reservation {
  id                 String            @id @default(cuid()) @map("id")
  reservationNumber  String            @unique @map("reservation_number")
  customerId         String            @map("customer_id")
  equipmentId        String            @map("equipment_id")
  startTime          DateTime          @map("start_time")
  endTime            DateTime          @map("end_time")
  duration           Int               @map("duration")
  estimatedPrice     Decimal           @map("estimated_price") @db.Decimal(10, 2)
  depositAmount      Decimal           @map("deposit_amount") @db.Decimal(10, 2)
  depositPaid        Boolean           @default(false) @map("deposit_paid")
  depositPaidAt      DateTime?         @map("deposit_paid_at")
  status             ReservationStatus @default(PENDING) @map("status")
  confirmedAt        DateTime?         @map("confirmed_at")
  reminderSent       Boolean           @default(false) @map("reminder_sent")
  reminderSentAt     DateTime?         @map("reminder_sent_at")
  noShow             Boolean           @default(false) @map("no_show")
  cancelledAt        DateTime?         @map("cancelled_at")
  cancellationReason String?           @map("cancellation_reason")
  notes              String?           @map("notes")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  customer           Customer          @relation(fields: [customerId], references: [id])
  equipment          Equipment         @relation(fields: [equipmentId], references: [id])

  @@index([customerId])
  @@index([equipmentId])
  @@index([startTime])
  @@index([status])
  @@map("reservations")
}

model MaintenanceTicket {
  id           String       @id @default(cuid()) @map("id")
  ticketNumber String       @unique @map("ticket_number")
  equipmentId  String       @map("equipment_id")
  title        String       @map("title")
  description  String       @map("description")
  priority     Priority     @default(MEDIUM) @map("priority")
  status       TicketStatus @default(OPEN) @map("status")
  diagnosis    String?      @map("diagnosis")
  solution     String?      @map("solution")
  assignedToId String?      @map("assigned_to_id")
  completedAt  DateTime?    @map("completed_at")
  resolvedAt   DateTime?    @map("resolved_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  assignedTo   User?        @relation(fields: [assignedToId], references: [id])
  equipment    Equipment    @relation(fields: [equipmentId], references: [id])

  @@index([equipmentId])
  @@index([status])
  @@index([priority])
  @@map("maintenance_tickets")
}

model DailyReport {
  id                  String   @id @default(cuid()) @map("id")
  date                DateTime @unique @map("date")
  dayOfWeek           Int      @map("day_of_week")
  gamingRevenue       Decimal  @default(0) @map("gaming_revenue") @db.Decimal(12, 2)
  boutiqueRevenue     Decimal  @default(0) @map("boutique_revenue") @db.Decimal(12, 2)
  totalRevenue        Decimal  @default(0) @map("total_revenue") @db.Decimal(12, 2)
  taxCollected        Decimal  @default(0) @map("tax_collected") @db.Decimal(12, 2)
  sessionCount        Int      @default(0) @map("session_count")
  totalHours          Decimal  @default(0) @map("total_hours") @db.Decimal(10, 2)
  uniqueCustomers     Int      @default(0) @map("unique_customers")
  newCustomers        Int      @default(0) @map("new_customers")
  cashPayments        Decimal  @default(0) @map("cash_payments") @db.Decimal(10, 2)
  mobileMoneyPayments Decimal  @default(0) @map("mobile_money_payments") @db.Decimal(10, 2)
  cardPayments        Decimal  @default(0) @map("card_payments") @db.Decimal(10, 2)
  topEquipment        Json?    @map("top_equipment")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([date])
  @@map("daily_reports")
}

model MonthlyReport {
  id                 String   @id @default(cuid()) @map("id")
  year               Int      @map("year")
  month              Int      @map("month")
  uniqueDate         DateTime @unique @map("unique_date")
  gamingRevenue      Decimal  @default(0) @map("gaming_revenue") @db.Decimal(12, 2)
  boutiqueRevenue    Decimal  @default(0) @map("boutique_revenue") @db.Decimal(12, 2)
  totalRevenue       Decimal  @default(0) @map("total_revenue") @db.Decimal(12, 2)
  monthlyTarget      Decimal  @map("monthly_target") @db.Decimal(12, 2)
  targetAchieved     Boolean  @map("target_achieved")
  achievementRate    Decimal  @map("achievement_rate") @db.Decimal(5, 2)
  sessionCount       Int      @default(0) @map("session_count")
  totalHours         Decimal  @default(0) @map("total_hours") @db.Decimal(10, 2)
  avgSessionDuration Decimal  @map("avg_session_duration") @db.Decimal(10, 2)
  uniqueCustomers    Int      @default(0) @map("unique_customers")
  newCustomers       Int      @default(0) @map("new_customers")
  returningCustomers Int      @default(0) @map("returning_customers")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([year, month])
  @@map("monthly_reports")
}

model CartItem {
  id         String    @id @default(cuid()) @map("id")
  sessionId  String    @unique @map("session_id")
  customerId String?   @map("customer_id")
  productId  String    @map("product_id")
  quantity   Int       @map("quantity")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  customer   Customer? @relation(fields: [customerId], references: [id])
  product    Product   @relation(fields: [productId], references: [id])

  @@index([sessionId])
  @@index([customerId])
  @@map("cart_items")
}

model AuditLog {
  id        String   @id @default(cuid()) @map("id")
  userId    String   @map("user_id")
  action    String   @map("action")
  entity    String   @map("entity")
  entityId  String   @map("entity_id")
  changes   Json?    @map("changes")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}

model Event {
  id          String         @id @default(cuid()) @map("id")
  title       String         @map("title")
  description String         @map("description")
  type        EventType      @map("type")
  eventDate   DateTime       @map("event_date")
  startTime   String         @map("start_time")
  endTime     String?        @map("end_time")
  price       Int            @default(0) @map("price")
  maxCapacity Int            @map("max_capacity")
  bookedCount Int            @default(0) @map("booked_count")
  imageUrl    String?        @map("image_url")
  location    String?        @map("location")
  isActive    Boolean        @default(true) @map("is_active")
  isPublished Boolean        @default(false) @map("is_published")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  bookings    EventBooking[]

  @@index([eventDate])
  @@index([type])
  @@index([isActive, isPublished])
  @@map("events")
}

model EventBooking {
  id              String    @id @default(cuid()) @map("id")
  eventId         String    @map("event_id")
  customerId      String?   @map("customer_id")
  attendeeName    String    @map("attendee_name")
  attendeeEmail   String    @map("attendee_email")
  attendeePhone   String?   @map("attendee_phone")
  numberOfTickets Int       @map("number_of_tickets")
  totalPrice      Int       @map("total_price")
  status          String    @default("confirmed") @map("status")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  customer        Customer? @relation(fields: [customerId], references: [id])
  event           Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([customerId])
  @@index([status])
  @@map("event_bookings")
}

enum UserRole {
  CASHIER
  TECHNICIAN
  MANAGER
  SHAREHOLDER
  ADMIN

  @@map("userrole")
}

enum CustomerStatus {
  NEW
  REGULAR
  VIP
  INACTIVE
  BLOCKED

  @@map("customerstatus")
}

enum EquipmentType {
  PS5
  PS4
  XBOX_SERIES_X
  XBOX_ONE
  PC_GAMING
  OCULUS_VR
  VR_PS4
  SIMU_RACING
  ARCADE
  RETRO

  @@map("equipmenttype")
}

enum EquipmentStatus {
  AVAILABLE
  IN_USE
  RESERVED
  MAINTENANCE
  BROKEN
  RETIRED

  @@map("equipmentstatus")
}

enum SessionStatus {
  PENDING
  ACTIVE
  PAUSED
  COMPLETED
  EXPIRED
  CANCELLED

  @@map("sessionstatus")
}

enum InvoiceType {
  GAMING_SESSION
  BOUTIQUE_SALE
  RESERVATION
  CREDIT_NOTE

  @@map("invoicetype")
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY_ORANGE
  MOBILE_MONEY_MTN
  CARD
  BANK_TRANSFER

  @@map("paymentmethod")
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIALLY_PAID
  CANCELLED
  REFUNDED

  @@map("paymentstatus")
}

enum MovementType {
  PURCHASE
  SALE
  RETURN
  ADJUSTMENT
  DAMAGE
  TRANSFER
  INITIAL

  @@map("movementtype")
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW

  @@map("reservationstatus")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT

  @@map("priority")
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_PARTS
  RESOLVED
  CLOSED

  @@map("ticketstatus")
}

enum EventType {
  COSPLAY
  TOURNAMENT
  GAME_LAUNCH
  SPECIAL
  CINE
  ANNIVERSARY

  @@map("eventtype")
}
